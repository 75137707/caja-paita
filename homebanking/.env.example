# Copiar estas variables al dashboard de Vercel (Project Settings -> Environment Variables)
# NO subir un .env real con datos reales al repositorio.

# Cadena de conexión que te da Aiven al crear el servicio MySQL (Service URI / Connection info)
# Formato: mysql+pymysql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=mysql+pymysql://avnadmin:TU_PASSWORD@TU_HOST-aivencloud.com:PUERTO/bd_core_financiero

# JWT
JWT_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_EXPIRE_MINUTES_ADMIN=20

# Seguridad
MAX_INTENTOS_FALLIDOS=3

# CORS: debe ser un JSON array con la URL exacta de tu frontend en Vercel
CORS_ORIGINS=["https://tu-frontend.vercel.app"]

APP_NAME=Homebanking Caja Virtual - API
